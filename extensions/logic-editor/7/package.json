{
	"name": "@septkit/ext-logic-editor",
	"displayName": "Logic Editor",
	"version": "7",
	"description": "Create function block diagrams to document logic",
	"private": true,
	"type": "module",
	"contributes": {
		"customEditors": [
			{
				"id": "sprinteins.ext-logic-editor.editor",
				"displayName": "Logic Editor",
				"icon": "/assets/icon.svg",
				"fileSelectors": [
					"SSD",
					"ASD",
					"SCD"
				],
				"entryPoint": "/set-editor.js"
			}
		]
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"build:watch": "vite build --watch",
		"build:serve": "concurrently \"npm run preview\" \"npm run build:watch\"",
		"preview": "vite preview --port 56683",
		"test": "vitest --project unit",
		"test:watch": "pnpm test --watch",
		"test:debug": "npm run test -- --browser.headless=false --browser.devtools=true --testTimeout 10000000",
		"test:debug:watch": "npm run test:debug -- --watch",
		"type-check": "vue-tsc --build",
		"lint": "oxlint . --fix -D correctness --ignore-path .gitignore",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"link:ui": "rm -rf ./node_modules/@septkit/ui && ln -s ../../../../ui ./node_modules/@septkit/ui",
		"unlink:ui": "rm -rf ./node_modules/@septkit/ui && pnpm install",
		"unlink:all": "rm -rf ./node_modules/@septkit && pnpm install",
		"ci-tests": "npm run format:check && npm run lint && npm run type-check && npm run build && npm run test"
	},
	"dependencies": {
		"@dialecte/core": "catalog:",
		"@dialecte/plc": "catalog:",
		"@dialecte/scl": "catalog:",
		"@lucide/vue": "^1.16.0",
		"@septkit/shell-lib": "catalog:",
		"@septkit/ui": "catalog:",
		"@tailwindcss/vite": "4.2.2",
		"@vueuse/core": "^14.2.1",
		"pinia": "^3.0.4",
		"reka-ui": "^2.9.7",
		"tailwindcss": "4.2.2",
		"vite-plugin-css-injected-by-js": "^3.5.2",
		"vite-plugin-static-copy": "^4.0.1",
		"vitest-browser-vue": "^2.1.0",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@testing-library/vue": "^8.1.0",
		"@tsconfig/node24": "24.0.0",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^22.19.17",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vitest/browser-playwright": "^4.1.4",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.9.1",
		"concurrently": "^9.2.1",
		"jiti": "^2.6.1",
		"npm-run-all2": "^8.0.4",
		"oxlint": "~1.6.0",
		"playwright": "^1.59.1",
		"prettier": "3.5.3",
		"typescript": "~5.8.3",
		"vite": "^8.0.8",
		"vite-plugin-vue-devtools": "^8.1.1",
		"vitest": "^4.1.4",
		"vue-tsc": "^3.2.6"
	}
}
