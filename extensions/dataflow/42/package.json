{
	"name": "@septkit/ext-dataflow",
	"version": "42",
	"displayName": "Dataflow",
	"description": "extension for SET Platform that provides dataflow capabilities between Logic-Nodes",
	"private": true,
	"type": "module",
	"contributes": {
		"customEditors": [
			{
				"id": "sprinteins.ext-dataflow.dataflow",
				"displayName": "Dataflow",
				"icon": "/assets/icon.svg",
				"fileSelectors": [
					"SSD",
					"ASD",
					"SCD"
				],
				"entryPoint": "set-editor.js"
			}
		]
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"build:watch": "npm run build -- --watch",
		"build:serve": "concurrently \"npm run preview\" \"npm run build:watch\"",
		"preview": "vite preview --port 54947",
		"test": "vitest --project unit",
		"test:watch": "pnpm test --watch",
		"test:debug": "npm run test -- --browser.headless=false --browser.devtools=true --testTimeout 10000000",
		"build-only": "vite build",
		"check": "npm run type:check && npm run format:check && npm run lint && npm run test",
		"type:check": "vue-tsc --build",
		"lint": "oxlint . --fix -D correctness --ignore-path .gitignore",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"install:browser": "pnpm exec playwright install chromium",
		"link:ui": "rm -rf ./node_modules/@septkit/ui && ln -s ../../../../ui ./node_modules/@septkit/ui",
		"unlink:ui": "rm -rf ./node_modules/@septkit/ui && pnpm install",
		"link:fileio": "rm -rf ./node_modules/@septkit/fileio && ln -s ../../../../fileio ./node_modules/@septkit/fileio",
		"unlink:fileio": "rm -rf ./node_modules/@septkit/fileio && pnpm install",
		"unlink:all": "rm -rf ./node_modules/@septkit && pnpm install"
	},
	"dependencies": {
		"@dialecte/core": "0.2.12",
		"@dialecte/scl": "0.2.8",
		"@septkit/fileio": "catalog:",
		"@septkit/shell-lib": "catalog:",
		"@septkit/ui": "catalog:",
		"@tailwindcss/vite": "4.2.2",
		"@vueuse/core": "^14.2.1",
		"daisyui": "^5.5.19",
		"dexie": "4.2.0",
		"pinia": "^3.0.4",
		"tailwindcss": "4.2.2",
		"vite-plugin-css-injected-by-js": "^3.5.2",
		"vite-plugin-static-copy": "^4.0.1",
		"vitest-browser-vue": "^2.1.0",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@testing-library/vue": "^8.1.0",
		"@tsconfig/node24": "24.0.0",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^22.19.17",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vitest/browser-playwright": "^4.1.4",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.9.1",
		"concurrently": "^9.2.1",
		"jiti": "^2.6.1",
		"npm-run-all2": "^8.0.4",
		"oxlint": "~1.6.0",
		"playwright": "^1.59.1",
		"prettier": "3.5.3",
		"typescript": "~5.8.3",
		"vite": "^8.0.8",
		"vite-plugin-vue-devtools": "^8.1.1",
		"vitest": "^4.1.4",
		"vue-tsc": "^3.2.6"
	}
}
