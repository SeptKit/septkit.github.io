{
	"name": "@septkit/ext-compare",
	"version": "6",
	"displayName": "Compare",
	"description": "Compare two SCL files side by side",
	"private": true,
	"type": "module",
	"contributes": {
		"customEditors": [
			{
				"id": "sprinteins.ext-compare.editor",
				"displayName": "Compare",
				"fileSelectors": [
					"SSD",
					"ASD",
					"SCD",
					"IID",
					"ICD"
				],
				"entryPoint": "/set-editor.js"
			}
		]
	},
	"scripts": {
		"dev": "vite",
		"//====== BUILD ======//": "",
		"build": "vite build",
		"build:watch": "vite build --watch",
		"build:serve": "concurrently \"npm run preview\" \"npm run build:watch\"",
		"preview": "vite preview --port 56000",
		"//====== TEST ======//": "",
		"test": "vitest --project unit",
		"test:watch": "pnpm test --watch",
		"test:debug": "npm run test -- --browser.headless=false --browser.devtools=true --testTimeout 10000000",
		"test:debug:watch": "npm run test:debug -- --watch",
		"//====== TOOLING ======//": "",
		"check": "run-p type-check lint format:check",
		"type-check": "vue-tsc --build",
		"lint": "oxlint . --fix -D correctness --ignore-path .gitignore",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"//====== LINK ======//": "",
		"link:ui": "rm -rf ./node_modules/@septkit/ui && ln -s ../../../../ui ./node_modules/@septkit/ui",
		"unlink:ui": "rm -rf ./node_modules/@septkit/ui && pnpm install",
		"unlink:all": "rm -rf ./node_modules/@septkit && pnpm install",
		"//====== CI ======//": "",
		"ci-tests": "npm run format:check && npm run lint && npm run build && npm run test"
	},
	"dependencies": {
		"@dialecte/core": "catalog:",
		"@dialecte/scl": "catalog:",
		"@lucide/vue": "^1.0.0",
		"@septkit/shell-lib": "catalog:",
		"@septkit/ui": "catalog:",
		"@tailwindcss/vite": "4.2.2",
		"pinia": "^3.0.4",
		"tailwindcss": "4.2.2",
		"vite-plugin-css-injected-by-js": "^3.5.2",
		"vite-plugin-static-copy": "^4.0.1",
		"vitest-browser-vue": "^2.1.0",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@prettier/plugin-oxc": "^0.0.4",
		"@tailwindcss/vite": "4.2.2",
		"@testing-library/vue": "^8.1.0",
		"@tsconfig/node24": "24.0.0",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^25.6.0",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vitest/browser-playwright": "^4.1.4",
		"@vitest/eslint-plugin": "^1.6.16",
		"@vue/eslint-config-prettier": "^10.2.0",
		"@vue/eslint-config-typescript": "^14.7.0",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.9.1",
		"concurrently": "^9.2.1",
		"daisyui": "^5.5.19",
		"eslint": "^10.2.1",
		"eslint-plugin-oxlint": "^1.61.0",
		"eslint-plugin-vue": "^10.8.0",
		"jiti": "^2.6.1",
		"npm-run-all2": "^8.0.4",
		"oxlint": "~1.61.0",
		"playwright": "catalog:",
		"prettier": "3.5.3",
		"typescript": "~5.8.3",
		"vite": "^8.0.8",
		"vite-plugin-vue-devtools": "^8.1.1",
		"vitest": "^4.1.4",
		"vue-tsc": "^3.2.6"
	}
}
