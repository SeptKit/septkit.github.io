{
	"name": "@septkit/ext-openscd-plugin-loader",
	"version": "20",
	"displayName": "OpenSCD Plugins",
	"type": "module",
	"description": "This is an example extension written in Vue.JS for SeptKit Platform",
	"contributes": {
		"customEditors": [
			{
				"id": "sprinteins.ext-openscd-plugin-loader.sld",
				"displayName": "Single Line Editor",
				"entryPoint": "/set-editor.js?plugin=https%3A%2F%2Fseptkit.github.io%2Foscd-editor-sld%2Foscd-editor-sld.js",
				"iframe": true
			},
			{
				"id": "sprinteins.ext-openscd-plugin-loader.template-generator",
				"displayName": "Template Generator",
				"entryPoint": "/set-editor.js?plugin=https%3A%2F%2Fseptkit.github.io%2Foscd-template-generator%2Foscd-template-generator.js%23%2F",
				"iframe": true
			},
			{
				"id": "sprinteins.ext-openscd-plugin-loader.template-updater",
				"displayName": "Template Updater",
				"entryPoint": "/set-editor.js?plugin=https%3A%2F%2Fseptkit.github.io%2Fscl-editor%2Fplugins%2Ftemplate-update%2Fscl-template-update.js",
				"iframe": true
			},
			{
				"id": "sprinteins.ext-openscd-plugin-loader.data-type-templates",
				"displayName": "DataType Templates",
				"entryPoint": "/set-editor.js?plugin=https%3A%2F%2Fseptkit.github.io%2Fscl-editor%2Fplugins%2Fscl-template%2Fscl-template.js",
				"iframe": true
			},
			{
				"id": "sprinteins.ext-openscd-plugin-loader.supervision",
				"displayName": "Supervision",
				"entryPoint": "/set-editor.js?plugin=https%3A%2F%2Fdanyill.github.io%2Foscd-supervision%2Foscd-supervision.js",
				"iframe": true
			}
		]
	},
	"scripts": {
		"dev": "NODE_ENV=dev vite",
		"//====== BUILD ======//": "",
		"build": "NODE_ENV=dev vite build",
		"build:acc": "NODE_ENV=acc vite build",
		"build:watch": "npm run build -- --watch",
		"build:serve": "concurrently \"npm run preview\" \"npm run build:watch\"",
		"preview": "vite preview --port 54944",
		"//====== TEST ======//": "",
		"test": "vitest --project unit",
		"test:watch": "npm run test -- --watch",
		"test:debug": "npm run test -- --browser.headless=false --browser.devtools=true --testTimeout 10000000",
		"test:debug:watch": "npm run test:debug -- --watch",
		"//====== TOOLING ======//": "",
		"check": "run-p type-check lint format:check",
		"type-check": "vue-tsc --build",
		"lint": "oxlint . --fix -D correctness --ignore-path .gitignore",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"//====== LINK ======//": "",
		"link:fileio": "rm -rf ./node_modules/@septkit/fileio && ln -s ../../../../fileio ./node_modules/@septkit/fileio",
		"unlink:fileio": "rm -rf ./node_modules/@septkit/fileio && pnpm install",
		"//====== CI ======//": "",
		"ci-tests": "npm run format:check && npm run lint && npm run build && npm run test"
	},
	"dependencies": {
		"@dialecte/core": "catalog:",
		"@dialecte/scl": "catalog:",
		"@openscd/oscd-api": "^0.1.6",
		"@septkit/fileio": "catalog:",
		"@septkit/shell-lib": "catalog:",
		"@septkit/ui": "catalog:",
		"@tailwindcss/vite": "4.2.2",
		"@vitejs/plugin-vue": "^6.0.5",
		"@webcomponents/scoped-custom-element-registry": "^0.0.10",
		"dexie": "4.2.0",
		"oxlint": "~1.6.0",
		"prettier": "3.5.3",
		"tailwindcss": "4.2.2",
		"vite": "^8.0.8",
		"vite-plugin-css-injected-by-js": "^3.5.2",
		"vite-plugin-static-copy": "^4.0.1",
		"vite-plugin-vue-devtools": "^8.1.1",
		"vitest-browser-vue": "^2.1.0",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@testing-library/vue": "^8.1.0",
		"@tsconfig/node24": "24.0.0",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^22.19.17",
		"@vitest/browser-playwright": "^4.1.4",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.9.1",
		"concurrently": "^9.2.1",
		"lodash-es": "^4.18.1",
		"playwright": "^1.59.1",
		"typescript": "~5.8.3",
		"vitest": "^4.1.4",
		"vue-tsc": "^3.2.6"
	}
}