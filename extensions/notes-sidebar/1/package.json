{
	"name": "@septkit/ext-notes-sidebar",
	"version": "1",
	"displayName": "Notes Sidebar",
	"description": "A sidebar extension for managing notes",
	"private": true,
	"type": "module",
	"contributes": {
		"primarySidebars": [
			{
				"id": "sprinteins.ext-notes-sidebar.sidebar",
				"displayName": "Notes",
				"icon": "/assets/icon.svg",
				"entryPoint": "/set-sidebar.js"
			}
		]
	},
	"scripts": {
		"dev": "vite",
		"//====== BUILD ======//": "",
		"build": "vite build",
		"build:watch": "vite build --watch",
		"build:serve": "concurrently \"npm run preview\" \"npm run build:watch\"",
		"preview": "vite preview --port 54945",
		"//====== TEST ======//": "",
		"test": "vitest --project unit",
		"test:watch": "pnpm test --watch",
		"test:debug": "npm run test -- --browser.headless=false --browser.devtools=true --testTimeout 10000000",
		"test:debug:watch": "npm run test:debug -- --watch",
		"//====== TOOLING ======//": "",
		"check": "run-p type-check lint format:check",
		"type-check": "vue-tsc --build",
		"lint": "oxlint . --fix -D correctness --ignore-path .gitignore",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"//====== LINK ======//": "",
		"link:ui": "rm -rf ./node_modules/@septkit/ui && ln -s ../../../../ui ./node_modules/@septkit/ui",
		"unlink:ui": "rm -rf ./node_modules/@septkit/ui && pnpm install",
		"link:fileio": "rm -rf ./node_modules/@septkit/fileio && ln -s ../../../../fileio ./node_modules/@septkit/fileio",
		"unlink:fileio": "rm -rf ./node_modules/@septkit/fileio && pnpm install",
		"unlink:all": "rm -rf ./node_modules/@septkit && pnpm install",
		"//====== CI ======//": "",
		"ci-tests": "npm run format:check && npm run lint && npm run build && npm run test"
	},
	"dependencies": {
		"@dialecte/core": "0.1.20",
		"@dialecte/scl": "0.1.18",
		"@septkit/fileio": "catalog:",
		"@septkit/sclsdk": "catalog:",
		"@septkit/ui": "catalog:",
		"dexie": "4.2.0",
		"lucide-vue-next": "1.0.0",
		"pinia": "^3.0.4",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@prettier/plugin-oxc": "^0.0.4",
		"@tailwindcss/vite": "4.2.2",
		"@testing-library/vue": "^8.1.0",
		"@tsconfig/node24": "24.0.0",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^22.19.17",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vitest/browser-playwright": "^4.1.4",
		"@vitest/eslint-plugin": "^1.6.15",
		"@vue/eslint-config-prettier": "^10.2.0",
		"@vue/eslint-config-typescript": "^14.7.0",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.9.1",
		"concurrently": "^9.2.1",
		"daisyui": "^5.5.19",
		"eslint": "^10.2.1",
		"eslint-plugin-oxlint": "^1.61.0",
		"eslint-plugin-vue": "^10.8.0",
		"jiti": "^2.6.1",
		"npm-run-all2": "^8.0.4",
		"oxlint": "~1.64.0",
		"playwright": "^1.59.1",
		"prettier": "3.6.2",
		"rxjs": "^7.8.2",
		"tailwindcss": "4.2.2",
		"typescript": "~5.9.3",
		"vite": "^8.0.8",
		"vite-plugin-css-injected-by-js": "^3.5.2",
		"vite-plugin-static-copy": "^4.0.1",
		"vite-plugin-vue-devtools": "^8.1.2",
		"vitest": "^4.1.4",
		"vitest-browser-vue": "^2.1.0",
		"vue-tsc": "^3.2.6"
	}
}
